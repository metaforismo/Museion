# Local zero-API-spend demo through an authenticated Codex runtime.
# Start with `codex login --device-auth`, then enable local subprocess access.
MUSEION_LOCAL_AI=1
# Optional when Codex is not on PATH (macOS ChatGPT bundle is auto-detected).
MUSEION_CODEX_BIN=/Applications/ChatGPT.app/Contents/Resources/codex

# Future explicit API mode only. Museion never selects this automatically.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6
OPENAI_COMPILER_MODEL=gpt-5.6

# Deployment-safe state. Leave as memory for local/keyless development.
# In production set MUSEION_STATE_BACKEND=supabase and provide both values
# below as server-only environment variables. Never prefix the secret with
# NEXT_PUBLIC_. SUPABASE_SERVICE_ROLE_KEY is also accepted for older projects.
MUSEION_STATE_BACKEND=memory
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Public canonical origin for metadata and social previews after deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
