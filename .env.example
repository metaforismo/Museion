# Required only for Maia's judged live GPT-5.6 tutoring path.
# Without it, the deterministic hint-ladder fallback remains available.
OPENAI_API_KEY=sk-...

# Optional. The GPT-5.6 Sol alias is the Build Week default.
OPENAI_MODEL=gpt-5.6
OPENAI_COMPILER_MODEL=gpt-5.6

# Public canonical origin for metadata and social previews after deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
